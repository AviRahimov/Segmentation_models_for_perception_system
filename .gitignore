# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Distribution / packaging
build/
develop-eggs/
dist/
eggs/
.eggs/
*.egg-info/
*.egg
wheels/
pip-wheel-metadata/
share/python-wheels/

# Virtual environments
.venv/
venv/
env/
ENV/
.python-version

# Editors / IDEs
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Type-checking / linting caches
.mypy_cache/
.ruff_cache/
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Logs
*.log
logs/

# PyTorch / model weights
*.pt
*.pth
# TorchScript serialized models (e.g. distilled YOLOE text encoders)
*.ts
*.onnx
*.engine
*.trt
*.plan
weights/
checkpoints/

# Datasets (heavy) — leading slash = root-level only, not src/perception/datasets/
# Use /datasets/* (not /datasets/) so subdirectory exceptions can work
/datasets/*
/data/
# Track detection dataset placeholder README only (not the data files themselves)
!/datasets/Detection_Dataset/
/datasets/Detection_Dataset/*
!/datasets/Detection_Dataset/README.md
*.zip
*.tar
*.tar.gz

# Outputs
output/
outputs/
runs/
*.mp4.part

# Hugging Face cache override (project-local)
.hf_cache/
cache/

# Jupyter
.ipynb_checkpoints/

# Project-local samples / media (heavy)
/samples

# Environment / secrets
.env
.env.*
# Use /reports/* (not /reports) so subdirectory exceptions can work
/reports/*
# Track placeholder dirs so collaborators see intended structure
!/reports/segmentation/
/reports/segmentation/*
!/reports/segmentation/.gitkeep
!/reports/detection/
/reports/detection/*
!/reports/detection/.gitkeep
